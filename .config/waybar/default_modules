{
	"layer": "top",
	"position": "top",
	"margin-top": 5,
	"margin-left": 5,
	"margin-right": 5,
	"spacing": 5,
	"modules-center": ["clock"],
	"modules-right": ["pulseaudio", "network", "cpu", "memory", "backlight", "battery", "tray"],

	"sway/workspaces": {
		"format": "{name}",
		"disable-scroll": true,
		"numeric-first": false,
	},
	"clock": {
		"on-click": "firefox https://calendar.google.com",
		"format": "{:<span weight=\"bold\">%I:%M %p</span> | %a. %B %d, %Y}"
	},
	"pulseaudio": {
		"on-click": "/usr/bin/pavucontrol",
		"format": "{icon} {volume}% | {format_source}",
		"format-bluetooth": "蟀偗 {volume}% | {format_source}",
		"format-bluetooth-muted": "蟀偗蟀潫 | {format_source}",
		"format-muted": "蟀潫 | {format_source}",
		"format-source": "蟀崿",
		"format-source-muted": "蟀嵀",
		"format-icons": {
			"headphone": "蟀媼",
			"headset": "蟀嫀",
			"default": ["蟀暱", "蟀杸", "蟀暰"]
		}
	},
	"network": {
		"on-click": "foot nmtui",
		"format-wifi": "{icon} {essid}",
		"format-icons": ["蟀", "蟀あ", "蟀ぅ", "蟀え"],
		"format-ethernet": "蟀垁 {ipaddr}",
		"format-disconnected": "蟀き disconnected",
		"tooltip-format-wifi": "{ipaddr} ({signalStrength}%)"
	},
	"cpu": {
		"on-click": "foot btm",
		"format": "蟀槡 {usage}%",
		"tooltip": false
	},
	"memory": {
		"on-click": "foot btm",
		"format": "蟀崨 {percentage}%",
	},
	"backlight": {
		"format": "蟀優 {percent}%"
	},
	"battery": {
		"format": "{icon} {time} ({capacity}%)",
		"format-charging": "蟀倓 {time} ({capacity}%)",
		"format-plugged": "蟀殽 {capacity}%",
		"format-icons": ["蟀伜", "蟀伝", "蟀伡", "蟀伣", "蟀伨", "蟀伩", "蟀個", "蟀倎", "蟀倐", "蟀伖"]
	},
	"tray": {
		"spacing": 10
	}
}
