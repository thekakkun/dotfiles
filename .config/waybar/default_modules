{
	"layer": "top",
	"position": "top",
	"margin-top": 5,
	"margin-left": 5,
	"margin-right": 5,
	"spacing": 5,
	"modules-center": ["clock"],
	"modules-right": ["pulseaudio", "network", "cpu", "memory", "backlight", "battery", "tray"],

	"sway/workspaces": {
		"format": "{name}",
		"disable-scroll": true,
		"numeric-first": false,
	},
	"clock": {
		"on-click": "firefox https://calendar.google.com",
		"format": "{:<span weight=\"bold\">%I:%M %p</span> | %a., %B %d}"
	},
	"pulseaudio": {
		"on-click": "/usr/bin/pavucontrol",
		"format": "{icon} {volume}% | {format_source}",
		"format-bluetooth": "≤░Γψ {volume}% | {format_source}",
		"format-bluetooth-muted": "≤░Γψ≤░ζθ | {format_source}",
		"format-muted": "≤░ζθ | {format_source}",
		"format-source": "≤░Ξυ",
		"format-source-muted": "≤░Ξφ",
		"format-icons": {
			"headphone": "≤░ΜΜ",
			"headset": "≤░ΜΟ",
			"default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
		}
	},
	"network": {
		"on-click": "foot nmtui",
		"format-wifi": "{icon} {essid}",
		"format-icons": ["≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
		"format-ethernet": "≤░ΙΑ {ipaddr}",
		"format-disconnected": "≤░νφ disconnected",
		"format-disabled": "≤░Αζ",
		"tooltip-format-wifi": "{ipaddr} ({signalStrength}%)"
	},
	"cpu": {
		"on-click": "foot btm",
		"format": "≤░αγ {usage}%",
		"tooltip": false
	},
	"memory": {
		"on-click": "foot btm",
		"format": "≤░Ξδ {percentage}%",
	},
	"backlight": {
		"format": "≤░Δη {percent}%"
	},
	"battery": {
		"format": "{icon} {capacity}% ({time})",
		"format-charging": "≤░ΓΕ {capacity}% ({time})",
		"format-plugged": "≤░γξ {capacity}%",
		"format-icons": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
	},
	"tray": {
		"spacing": 10
	}
}
